{
  "model": {
    "name": "gemini-3.1-pro-preview"
  },
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ]
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp"
      ]
    },
    "pdf": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-pdf",
        "--stdio"
      ]
    }
  }
}